{
  "name": "startupdocs",
  "startCommand": "./start.sh",
  "envVars": {
    "GEMINI_API_KEY": {
      "description": "Optional. Google Gemini API key. If no provider keys are set, the app uses its built-in deterministic generator.",
      "example": "AIza..."
    },
    "OPENROUTER_API_KEY": {
      "description": "Optional. OpenRouter API key.",
      "example": "sk-or-..."
    },
    "GROQ_API_KEY": {
      "description": "Optional. Groq API key.",
      "example": "gsk_..."
    },
    "MISTRAL_API_KEY": {
      "description": "Optional. Mistral API key.",
      "example": "..."
    }
  }
}
