GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-1.5-flash
MISTRAL_MODEL=mistral-small-latest
STARTUPDOCS_PROVIDER_ORDER=openrouter,groq,gemini,mistral

# Backend: comma-separated frontend origins allowed by CORS (use "*" to allow all)
STARTUPDOCS_CORS_ORIGINS=http://localhost:3000
# Backend: database connection (defaults to local SQLite if unset)
DATABASE_URL=sqlite:///./startupdocs.db

# Frontend: public URL of the backend API (inlined at build time)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
